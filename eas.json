{
  "cli": {
    "version": ">= 20.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle",
        "enableProguardInReleaseBuilds": true,
        "extraProguardRules": "-keepattributes SourceFile,LineNumberTable"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
