{
  "expo": {
    "name": "Libre",
    "slug": "libre",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "libre",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lacerda.libre"
    },
    "android": {
      "package": "com.lacerda.libre",
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#1fb485"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "color": "#10B981"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1fb485",
          "image": "./assets/splash_icon.png",
          "imageWidth": 150
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0fdd71fe-c25b-4d24-9a3d-0ae1e76be42b"
      }
    }
  }
}
